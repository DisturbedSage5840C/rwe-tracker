# Application identity
APP_NAME=RWE Perception Tracker API  # Human-readable service name for logs/metadata
ENVIRONMENT=development              # Environment label: development|staging|production
API_PORT=8000                        # FastAPI service port

# Core infrastructure
DATABASE_URL=postgresql+asyncpg://rwe:rwe@postgres:5432/rwe_tracker  # Async SQLAlchemy DSN
REDIS_URL=redis://redis:6379/0                                      # Redis URL for cache and Celery

# Security and auth
SECRET_KEY=change-me-in-production          # JWT signing key (use secure secret manager in prod)
JWT_ALGORITHM=HS256                         # JWT signing algorithm
ACCESS_TOKEN_EXPIRE_MINUTES=15              # JWT access token expiration window
REFRESH_TOKEN_EXPIRE_DAYS=30                # Refresh token validity window in days
AUTHENTICATED_RATE_LIMIT=100/minute         # Authenticated caller throttle policy
UNAUTHENTICATED_RATE_LIMIT=10/minute        # Public caller throttle policy

# Service integrations
NLP_SERVICE_URL=http://nlp:8001             # Internal URL for NLP microservice
NLP_BATCH_SIZE=100                          # Worker-to-NLP batch size for /analyze/batch calls
NLP_MAX_BATCH_SIZE=500                      # Hard upper bound accepted by NLP service
OPENAI_API_KEY=replace-with-real-key        # LLM provider key for enrichment pipelines
OPENFDA_BASE_URL=https://api.fda.gov        # Base URL for openFDA ingestion
REDDIT_CLIENT_ID=replace-reddit-client-id   # Reddit API client id for ingestion worker
REDDIT_CLIENT_SECRET=replace-reddit-secret   # Reddit API client secret for ingestion worker
REDDIT_USER_AGENT=rwe-tracker-bot/1.0       # Reddit-compliant user agent string

# Frontend runtime
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000  # Browser-visible API base URL for frontend
